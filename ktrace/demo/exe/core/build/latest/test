#!/usr/bin/env bash
set -euo pipefail
base_classpath="/home/karmak/dev/ktools/ktools-kotlin/ktrace/demo/exe/core/build/latest/classes:/home/karmak/dev/ktools/ktools-kotlin/ktrace/build/latest/sdk/classes:/home/karmak/dev/ktools/ktools-kotlin/kcli/build/latest/sdk/classes"
find_kotlin_lib_dir() {
  candidates=()
  if [ -n "${KOTLIN_HOME:-}" ]; then
    candidates+=("$KOTLIN_HOME/lib" "$KOTLIN_HOME")
  fi
  if command -v kotlinc >/dev/null 2>&1; then
    kotlinc_bin="$(command -v kotlinc)"
    candidates+=("$(dirname "$kotlinc_bin")/../lib" "$(dirname "$kotlinc_bin")/../../lib")
  fi
  candidates+=("/snap/kotlin/current/lib" "/usr/share/kotlin/kotlinc/lib" "/usr/lib/kotlin/lib" "/usr/local/lib/kotlin/lib" "/opt/kotlinc/lib")
  for candidate in "${candidates[@]}"; do
    if [ -f "$candidate/kotlin-stdlib.jar" ]; then
      printf "%s\n" "$candidate"
      return 0
    fi
  done
  return 1
}
kotlin_lib_dir="$(find_kotlin_lib_dir || true)"
runtime_entries=()
if [ -n "$kotlin_lib_dir" ]; then
  for jar in "$kotlin_lib_dir"/kotlin-stdlib*.jar "$kotlin_lib_dir"/kotlin-reflect*.jar; do
    if [ -f "$jar" ]; then
      runtime_entries+=("$jar")
    fi
  done
fi
runtime_classpath=""
if [ "${#runtime_entries[@]}" -gt 0 ]; then
  runtime_classpath="${runtime_entries[0]}"
  for ((i=1; i<${#runtime_entries[@]}; ++i)); do
    runtime_classpath="$runtime_classpath:${runtime_entries[$i]}"
  done
fi
if [ -n "$runtime_classpath" ]; then
  exec java -cp "$base_classpath:$runtime_classpath" ktrace.demo.core.Main "$@"
fi
if command -v kotlin >/dev/null 2>&1; then
  exec kotlin -cp "$base_classpath" ktrace.demo.core.Main "$@"
fi
echo "kotlin runtime is unavailable; install kotlin/kotlinc or set KOTLIN_HOME" >&2
exit 1
